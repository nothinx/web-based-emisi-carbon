# Salin ke .env dan sesuaikan.

# Dev (SQLite, async) — default jika tidak di-set.
DATABASE_URL=sqlite+aiosqlite:///./carbon.db

# Production (PostgreSQL) — tinggal ganti string ini, model sudah Postgres-ready (JSONB/UUID).
# DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/carbon

# Auth
JWT_SECRET=change-me-in-production-please
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# API key untuk jalur IoT ingestion (Phase 4) — pisahkan user vs mesin.
INGESTION_API_KEY=dev-ingestion-key-change-me

# CORS untuk frontend Vite dev server.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
